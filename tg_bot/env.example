# Скопируйте в tg_bot/.env (файл в .gitignore).
# Источник: tg_bot/src/app/core/config.py

# Токен от @BotFather
BOT_TOKEN=123456789:CHANGE_ME_BOT_TOKEN

# Внутри Docker-сети: предпочтительно nginx gateway (единая точка входа):
BACKEND_BASE_URL=http://gateway
# Альтернатива — напрямую в API: http://backend:8000

# Публичный базовый URL API (как PUBLIC_BACKEND_BASE_URL в backend/.env).
# В коде поле public_backend_base_url; в .env — UPPER_SNAKE_CASE.
# На стенде test/prod: бот AcomOfferDesk и ваши URL, не dev-бот и не чужой ngrok из примеров.
# После смены tunnel/VPS: docker compose up -d --force-recreate tg_bot
PUBLIC_BACKEND_BASE_URL=http://localhost:8080

# Таймаут HTTP к бэкенду (секунды)
REQUEST_TIMEOUT_SECONDS=5.0
