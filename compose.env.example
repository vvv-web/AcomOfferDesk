# Скопируйте в `.env` в корне репозитория (рядом с docker-compose.yml).
# Docker Compose подставляет эти переменные при интерполяции ${VAR} в compose-файле.
# Секреты в Git не коммитить — только локально на сервере.

# MinIO (сервис minio в compose; те же значения используйте в backend/env.example для S3_*)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD

# RabbitMQ в текущем docker-compose.yml приложения не читает эти переменные из корневого .env —
# учётные данные задаются в RABBITMQ_URL в backend/.env (по умолчанию guest:guest).
# Если добавите environment для сервиса rabbitmq, раскомментируйте и согласуйте с RABBITMQ_URL:
# RABBITMQ_DEFAULT_USER=guest
# RABBITMQ_DEFAULT_PASS=guest
