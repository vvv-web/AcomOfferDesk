# Copy this file to `.env` next to `docker-compose.yml`.
# These values are used by Docker Compose interpolation only.

# MinIO root credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD

# Optional compose override for Keycloak startup mode.
# Use `start-dev` locally and `start` behind a real reverse proxy in production.
KEYCLOAK_START_COMMAND=start-dev

# Build-time toggle for the temporary local login form in the web UI.
VITE_ENABLE_LEGACY_LOGIN=true
