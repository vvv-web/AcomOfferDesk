# Скопируйте в `.env` в корне репозитория (рядом с docker-compose.yml).
# Docker Compose подставляет эти переменные при интерполяции ${VAR} в compose-файле.
# Секреты в Git не коммитить — только локально на сервере.

# MinIO (сервис minio в compose; те же значения используйте в backend/env.example для S3_*)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD
