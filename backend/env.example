# Copy this file to `backend/.env`. Do not commit real secrets.
# Variable names are read by `backend/app/core/config.py`.
# Ниже — целевые значения для production VPS; локально для разработки задайте APP_ENV=development при необходимости.

APP_ENV=production

# --- PostgreSQL application database ---
DATABASE_URL=postgresql://CHANGE_USER:CHANGE_PASSWORD@order-database-postgres:5432/order_database

# --- Legacy local JWT/session settings (kept for staged rollout) ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=60
ACCESS_TOKEN_TTL_SECONDS=300
REFRESH_TOKEN_IDLE_TTL_SECONDS=1800
REFRESH_TOKEN_MAX_TTL_SECONDS=43200
REFRESH_COOKIE_NAME=acom_refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
# REFRESH_COOKIE_DOMAIN=
# REFRESH_TOKEN_SECRET=

# --- Keycloak / OIDC ---
KEYCLOAK_ENABLED=true
AUTH_ENABLE_LEGACY_PASSWORD_LOGIN=true
KEYCLOAK_REALM=acom-offerdesk
KEYCLOAK_CLIENT_ID=acom-offerdesk-web
KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080/iam
KEYCLOAK_PUBLIC_BASE_URL=http://localhost:8080/iam
KEYCLOAK_ISSUER_URL=http://localhost:8080/iam/realms/acom-offerdesk
KEYCLOAK_JWKS_CACHE_TTL_SECONDS=300
KEYCLOAK_HTTP_TIMEOUT_SECONDS=10
KEYCLOAK_REFRESH_COOKIE_NAME=acom_oidc_refresh
KEYCLOAK_STATE_COOKIE_NAME=acom_oidc_state
KEYCLOAK_BOOTSTRAP_BINDING_ENABLED=true
KEYCLOAK_BOOTSTRAP_APP_USERNAME=superadmin
KEYCLOAK_VERIFY_EMAIL=true
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
# Dev: автоматическая привязка по username (для локальной отладки; на production обычно false).
KEYCLOAK_DEV_AUTO_LINK_BY_USERNAME_ENABLED=false
# Prod: привязка существующего пользователя по подтверждённому email из Keycloak.
KEYCLOAK_PROD_AUTO_LINK_BY_VERIFIED_EMAIL_ENABLED=true

# --- Keycloak container bootstrap ---
KEYCLOAK_START_COMMAND=start-dev
KC_BOOTSTRAP_ADMIN_USERNAME=kc_bootstrap_admin
KC_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_MASTER_ADMIN_PASSWORD
KEYCLOAK_BOOTSTRAP_APP_PASSWORD=CHANGE_ME_APP_SUPERADMIN_PASSWORD
KEYCLOAK_BOOTSTRAP_APP_EMAIL=superadmin@example.com
KEYCLOAK_BOOTSTRAP_APP_FIRST_NAME=Bootstrap
KEYCLOAK_BOOTSTRAP_APP_LAST_NAME=Superadmin

# --- Keycloak PostgreSQL schema (same DB, isolated schema) ---
KC_DB=postgres
KC_DB_URL_HOST=order-database-postgres
KC_DB_URL_PORT=5432
KC_DB_URL_DATABASE=order_database
KC_DB_USERNAME=CHANGE_USER
KC_DB_PASSWORD=CHANGE_PASSWORD
KC_DB_SCHEMA=keycloak
KC_HTTP_ENABLED=true
KC_HTTP_RELATIVE_PATH=/iam
KC_PROXY_HEADERS=xforwarded
KC_HEALTH_ENABLED=true
KC_METRICS_ENABLED=true
KC_HOSTNAME=http://localhost:8080/iam

# --- Public URLs ---
WEB_BASE_URL=http://localhost:8080
PUBLIC_BACKEND_BASE_URL=http://localhost:8080
# Для ссылок внутри Telegram нужен публичный URL, доступный извне.
# localhost подходит для браузера на этой машине, но не подходит для inline-кнопок Telegram.
TG_BOT_PUBLIC_URL=https://t.me/YOUR_BOT_USERNAME

# --- Telegram links ---
TG_LINK_SECRET=CHANGE_ME_RANDOM_SECRET

# --- SMTP / email verification ---
# Эти же настройки используются для SMTP в Keycloak.
EMAIL_ADDRESS=your-mail@example.com
EMAIL_FROM_NAME=AcomOfferDesk
EMAIL_APP_PASSWORD=CHANGE_APP_PASSWORD
SMTP_HOST=smtp.example.com
SMTP_PORT=465
# Необязательные override-параметры именно для Keycloak:
# KEYCLOAK_SMTP_USERNAME=
# KEYCLOAK_SMTP_PASSWORD=
# KEYCLOAK_SMTP_FROM=
# KEYCLOAK_SMTP_REPLY_TO=
# KEYCLOAK_SMTP_FROM_DISPLAY_NAME=
# KEYCLOAK_SMTP_SSL=true
# KEYCLOAK_SMTP_STARTTLS=false

# --- IMAP (optional) ---
# IMAP_HOST=
# IMAP_PORT=993
# IMAP_USERNAME=
# IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
REQUEST_MAILBOX_POLL_LIMIT=20
REQUEST_MAILBOX_POLL_INTERVAL_SECONDS=60

# --- Email token secrets ---
EMAIL_VERIFICATION_SECRET=CHANGE_ME_EMAIL_VERIFICATION_SECRET
EMAIL_VERIFICATION_TTL_SECONDS=3600
EMAIL_REPLY_SECRET=CHANGE_ME_EMAIL_REPLY_SECRET
EMAIL_REPLY_TTL_SECONDS=604800

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- S3 / MinIO ---
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME_SAME_AS_MINIO_ROOT_PASSWORD
S3_BUCKET=acom-offer-desk
S3_SECURE=false
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_PRESIGNED_GET_TTL_SECONDS=300
MAX_UPLOAD_SIZE_BYTES=10485760

# --- Telegram flow TTLs ---
TG_REGISTER_TTL_SECONDS=86400
TG_AUTH_TTL_SECONDS=600
TG_REQUEST_TTL_SECONDS=604800

# --- CORS ---
# CORS_ALLOW_ORIGINS=http://localhost:8080,https://your-domain.example
