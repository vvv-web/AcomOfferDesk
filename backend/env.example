# Скопируйте в backend/.env (файл в .gitignore).
# Источник имён переменных: backend/app/core/config.py (Pydantic Settings).

# --- PostgreSQL (имя хоста = контейнер из order_database compose, сеть project_net) ---
# Пример, если БД из alexonderia/order_database без смены имён сервиса:
# DATABASE_URL=postgresql://USER:PASSWORD@order-database-postgres:5432/DBNAME
DATABASE_URL=postgresql://CHANGE_USER:CHANGE_PASSWORD@order-database-postgres:5432/order_database

# --- JWT и cookie сессии ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=60
ACCESS_TOKEN_TTL_SECONDS=300
REFRESH_TOKEN_IDLE_TTL_SECONDS=1800
REFRESH_TOKEN_MAX_TTL_SECONDS=43200
REFRESH_COOKIE_NAME=acom_refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
# REFRESH_COOKIE_DOMAIN=
# REFRESH_TOKEN_SECRET=  # если пусто, используется JWT_SECRET

# --- Публичные URL (после localtunnel/VPS домен — обновить и пересоздать backend + tg_bot) ---
WEB_BASE_URL=http://localhost:8080
PUBLIC_BACKEND_BASE_URL=http://localhost:8080
# Ссылка для Telegram deep-link / писем:
TG_BOT_PUBLIC_URL=https://t.me/YOUR_BOT_USERNAME

# --- Telegram (ссылки из бэкенда) ---
TG_LINK_SECRET=CHANGE_ME_RANDOM_SECRET

# --- Почта (SMTP обязателен для верификации) ---
EMAIL_ADDRESS=your-mail@example.com
EMAIL_FROM_NAME=AcomOfferDesk
EMAIL_APP_PASSWORD=CHANGE_APP_PASSWORD
SMTP_HOST=smtp.example.com
SMTP_PORT=465

# --- IMAP (опционально; чтение ответов по почте) ---
# IMAP_HOST=
# IMAP_PORT=993
# IMAP_USERNAME=  # по умолчанию EMAIL_ADDRESS
# IMAP_PASSWORD=  # по умолчанию EMAIL_APP_PASSWORD
IMAP_MAILBOX=INBOX
REQUEST_MAILBOX_POLL_LIMIT=20
REQUEST_MAILBOX_POLL_INTERVAL_SECONDS=60

# --- Токены для писем ---
EMAIL_VERIFICATION_SECRET=CHANGE_ME_EMAIL_VERIFICATION_SECRET
EMAIL_VERIFICATION_TTL_SECONDS=3600
EMAIL_REPLY_SECRET=CHANGE_ME_EMAIL_REPLY_SECRET
EMAIL_REPLY_TTL_SECONDS=604800

# --- RabbitMQ (внутри compose: сервис rabbitmq) ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- S3 / MinIO (внутри compose: endpoint без https, secure=false) ---
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME_SAME_AS_MINIO_ROOT_PASSWORD
# Имя бакета должно совпадать с созданным в MinIO (примеры: acom-offer-desk, acom-offerdesk).
S3_BUCKET=acom-offer-desk
S3_SECURE=false
# Публичный URL для клиентов (если MinIO с пробросом порта): http://VPS_IP:9000 или https://...
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_PRESIGNED_GET_TTL_SECONDS=300
MAX_UPLOAD_SIZE_BYTES=10485760

# --- Telegram-регистрация / сроки ссылок ---
TG_REGISTER_TTL_SECONDS=86400
TG_AUTH_TTL_SECONDS=600
TG_REQUEST_TTL_SECONDS=604800

# --- CORS (опционально, список через запятую) ---
# CORS_ALLOW_ORIGINS=http://localhost:8080,https://your-tunnel.loca.lt
